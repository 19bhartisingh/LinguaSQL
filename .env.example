# ══════════════════════════════════════════════════════
#  LinguaSQL — Environment Variables
#  Set ALL of these in Railway → your project → Variables tab.
#  Never commit a filled-in .env file to Git!
# ══════════════════════════════════════════════════════

# ── AI Provider Keys (at least one required) ─────────
# Google Gemini — free tier: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_key_here

# Groq LLaMA — free tier: https://console.groq.com
GROQ_API_KEY=your_groq_key_here

# OpenAI GPT (paid)
OPENAI_API_KEY=your_openai_key_here

# ── Security (REQUIRED in production) ────────────────
# Encrypts stored API keys in the database.
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
QM_SECRET_KEY=change-me-to-a-random-32-char-secret

# JWT signing secret for user authentication.
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
QM_JWT_SECRET=change-me-to-a-different-random-64-hex-chars
QM_JWT_EXPIRE_DAYS=30

# ── Server ────────────────────────────────────────────
# Railway sets PORT automatically — you do NOT need to set this manually.
# Only set it if running locally with docker run.
PORT=8000

# ── Scheduled Email Reports (optional) ───────────────
# Required only if you want email alerts / scheduled reports.
# Gmail: enable 2FA → create App Password (16 chars, no spaces)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your_16char_app_password
SMTP_FROM=you@gmail.com
